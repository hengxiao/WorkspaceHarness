# Generated by `harness bootstrap`. Hand-edits inside HARNESS:KEEP blocks survive.
FROM {{ base_image }}

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
      git make curl jq ca-certificates build-essential \
      python3 python3-pip python3-venv \
      && rm -rf /var/lib/apt/lists/*

# --- harness CLI -------------------------------------------------------------
COPY cli/ /opt/harness-cli/
RUN pip install --break-system-packages /opt/harness-cli

# --- per-project runtime layers ---------------------------------------------
# Rendered from runtime_blocks (data-driven). Override or add new runtimes
# via env.runtime_blocks in harness.yml.
{% for lang in all_languages %}
{% if lang in runtime_blocks %}
# {{ lang }}
{{ runtime_blocks[lang] }}
{% endif %}
{% endfor %}

# HARNESS:KEEP:BEGIN custom-tooling
# Add custom RUN/COPY steps here. They survive `harness bootstrap`.
# HARNESS:KEEP:END custom-tooling

WORKDIR /work
ENTRYPOINT ["bash", "-lc"]
CMD ["bash"]
