# Generated by `harness bootstrap`. Hand-edits inside HARNESS:KEEP blocks survive.

services:
  dev:
    build:
      context: ..
      dockerfile: env/Dockerfile
    image: harness-dev
    working_dir: /work
    # Keep the container alive for `make up` + `make exec` pattern.
    # Dependencies installed via `make deps` persist until `make down`.
    stdin_open: true
    tty: true
    volumes:
      - ../:/work:cached
    environment:
      - HARNESS_ROOT=/work
{% if services %}
    depends_on:
{% for s in services %}
      - {{ s.name }}
{% endfor %}
{% endif %}
    # HARNESS:KEEP:BEGIN dev-extras
    # Add ports, env, or extra mounts here.
    # HARNESS:KEEP:END dev-extras

{% for s in services %}
  {{ s.name }}:
    image: {{ s.image }}
{% if s.get('ports') %}
    ports:
{% for p in s.ports %}
      - "{{ p }}"
{% endfor %}
{% endif %}
{% if s.get('environment') %}
    environment:
{% for k, v in s.environment.items() %}
      {{ k }}: "{{ v }}"
{% endfor %}
{% endif %}
{% if s.get('volumes') %}
    volumes:
{% for v in s.volumes %}
      - {{ v }}
{% endfor %}
{% endif %}

{% endfor %}

# HARNESS:KEEP:BEGIN extra-services
# Declare additional services here.
# HARNESS:KEEP:END extra-services
